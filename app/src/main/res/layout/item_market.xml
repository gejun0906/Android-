<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 顶部：名称和徽章 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_market_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="超市名称"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <ImageView
                android:id="@+id/img_high_rating"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/star_big_on"
                android:visibility="gone"
                android:tint="#4CAF50" />

            <TextView
                android:id="@+id/tv_high_rating_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高评分"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#4CAF50"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginLeft="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 地址 -->
        <TextView
            android:id="@+id/tv_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="地址"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="4dp" />

        <!-- 评分栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <RatingBar
                android:id="@+id/rating_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.1"
                android:rating="4.5"
                android:isIndicator="true"
                style="?android:attr/ratingBarStyleSmall" />

            <TextView
                android:id="@+id/tv_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.5"
                android:textSize="14sp"
                android:textColor="#FF9800"
                android:textStyle="bold"
                android:layout_marginLeft="8dp" />

            <TextView
                android:id="@+id/tv_freshness_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新鲜度: 4.8"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginLeft="12dp" />
        </LinearLayout>

        <!-- 营业状态和时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="营业中"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_business_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00-22:00"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginLeft="8dp" />
        </LinearLayout>

        <!-- 描述 -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="描述信息"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginTop="6dp" />

        <!-- 底部：评价数量和查看按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_review_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="100条评价"
                android:textSize="12sp"
                android:textColor="#999999" />

            <TextView
                android:id="@+id/tv_view_reviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看评价 >"
                android:textSize="13sp"
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:clickable="true" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
